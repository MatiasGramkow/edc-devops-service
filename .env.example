# edc-devops-service — environment variables
# For local dev, copy to .env.local and fill in. .env.local is gitignored.

# === Azure DevOps API (required) ===
AZURE_DEVOPS_ORG=edc-group
AZURE_DEVOPS_PROJECT=Relaunch - Charlie Tango
AZURE_DEVOPS_PAT=

# === Rate limiting (optional) ===
RATE_LIMIT_RPM=30

# === AI features (optional) ===
# Path to a related codebase that the AI Summary feature greps for context.
RELATED_CODEBASE_PATH=
# Either OpenAI or Anthropic — used for code summaries and TOPdesk transforms.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Authentication ===
# Production runs behind App Service Easy Auth, which injects
#   x-ms-client-principal  (base64-JSON of user claims)
# on every request. The app reads identity from that header — no
# client secret, no MSAL, no OAuth flow in this codebase.
#
# Local dev has no Easy Auth in front of it, so getCurrentUser()
# returns a stub user. Optionally override the stub identity:
DEV_USER_UPN=magr@edc.dk
DEV_USER_NAME=Matias Gramkow (dev)
